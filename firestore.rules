rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Identity & role helpers ──────────────────────────────────────────────
    // Roles are carried as a custom claim set only by the admin-only
    // `provisionUser` Cloud Function, so a client can never escalate itself.
    function isSignedIn() {
      return request.auth != null;
    }
    function role() {
      return isSignedIn() ? request.auth.token.role : "anon";
    }
    function isAdmin() {
      return role() == "admin";
    }
    function isOps() {
      return role() == "ops" || isAdmin();
    }
    function isVendor() {
      return role() == "vendor";
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // The vendor's stall id is pinned into their token at provisioning time, so
    // one vendor can never touch another vendor's stall or orders.
    function myStallId() {
      return isSignedIn() ? request.auth.token.stallId : "";
    }
    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ── users: profile + role. Role/stallId are claim-mirrored, never client-set.
    match /users/{uid} {
      allow read: if isOwner(uid) || isOps();
      allow list: if isAdmin();
      // A user creates only their own doc with the base `fan` role. They MAY set
      // status "pending" + a requestedRole (a request, not a grant) — the actual
      // elevated claim is only ever set server-side on admin approval.
      allow create: if isOwner(uid)
        && request.resource.data.role == "fan"
        && request.resource.data.active == true
        && request.resource.data.status in ["active", "pending"];
      // Owner may edit display prefs only; never role/active/status/stallId.
      allow update: if (isOwner(uid)
          && unchanged("role") && unchanged("active")
          && unchanged("status") && unchanged("stallId"))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // ── accessRequests: a user files their own; ops/admin review; only server
    // (Admin SDK) or admin may decide. The elevated claim is granted by the
    // approveAccessRequest function, so filing a request grants nothing.
    match /accessRequests/{reqId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.requestedRole in ["vendor", "ops"];
      allow read, list: if isOps();
      allow update, delete: if isAdmin();
    }

    // ── fanProfiles: the personal matchday plan input. Strictly owner-scoped. ──
    match /fanProfiles/{uid} {
      allow read, write: if isOwner(uid);
      allow read: if isOps();
    }

    // ── matches + cached AI content: public read, admin-only write. ───────────
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
      // Per-language Gemini content cache is written only by Cloud Functions
      // (Admin SDK bypasses rules); clients read it.
      match /content/{lang} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── stalls: fans read; the owning vendor edits its own stall; admin all. ──
    match /stalls/{stallId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isVendor() && myStallId() == stallId
            && unchanged("vendorUid") && unchanged("zone"));
    }

    // ── orders: fan creates own; fan reads own; owning vendor reads/advances. ─
    match /orders/{orderId} {
      allow create: if isSignedIn()
        && request.resource.data.fanUid == request.auth.uid
        && request.resource.data.status == "placed"
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 25;
      allow read: if isOwner(resource.data.fanUid)
        || (isVendor() && resource.data.stallId == myStallId())
        || isOps();
      // Fan may only cancel while still 'placed'. Vendor advances status and
      // may change nothing else on the order.
      allow update: if
        (isOwner(resource.data.fanUid)
          && resource.data.status == "placed"
          && request.resource.data.status == "cancelled"
          && changedKeys().hasOnly(["status", "timeline"]))
        || (isVendor() && resource.data.stallId == myStallId()
          && changedKeys().hasOnly(["status", "timeline"]));
      allow delete: if false;
    }

    // ── amenities: public read; ops toggles live status only. ─────────────────
    match /amenities/{amenityId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isOps() && changedKeys().hasOnly(["status", "updatedAt"]);
    }

    // ── simulator-fed operational collections: read for staff, write server-only.
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if false;
    }
    match /gates/{gateId} {
      allow read: if true;
      allow write: if false;
    }
    match /transitLines/{lineId} {
      allow read: if true;
      allow write: if false;
    }
    match /opsBriefs/{briefId} {
      allow read: if isOps();
      allow write: if false;
    }

    // ── incidents: fans report; ops triage/resolve. ───────────────────────────
    match /incidents/{incidentId} {
      allow create: if isSignedIn()
        && request.resource.data.source == "fan"
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 500;
      allow read: if isOps()
        || (isSignedIn() && resource.data.reportedBy == request.auth.uid);
      allow update, delete: if isOps();
    }

    // ── social wall (P1): authored posts, moderated server-side before publish.
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 280
        && request.resource.data.published == false;
      allow update: if isOps() || isAdmin(); // moderation / publish flip
      allow delete: if isOps() || isAdmin()
        || (isSignedIn() && resource.data.authorUid == request.auth.uid);
    }

    // ── polls (P1): admin/ops create; one vote per user enforced structurally. ─
    match /polls/{pollId} {
      allow read: if isSignedIn();
      allow create, delete: if isOps() || isAdmin();
      allow update: if false; // counts are aggregated by a Cloud Function
      match /votes/{uid} {
        allow read: if isOwner(uid) || isOps();
        // A user writes exactly one vote doc keyed by their own uid, once.
        allow create: if isOwner(uid) && !exists(/databases/$(database)/documents/polls/$(pollId)/votes/$(uid));
        allow update, delete: if false;
      }
    }

    // Deny-by-default: any collection not matched above is inaccessible.
  }
}
