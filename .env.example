# ─────────────────────────────────────────────────────────────────────────────
# StadiumSense — frontend environment (Vite exposes only VITE_* to the client)
# Copy to `.env.local` and fill with your Firebase web app config.
# NEVER put server secrets (Gemini / Maps server keys) here — they live only in
# Cloud Functions via Secret Manager. See functions/.env.example.
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (reCAPTCHA Enterprise site key — public by design)
VITE_RECAPTCHA_SITE_KEY=

# Google Maps JS API key for the client map widget.
# Restrict this key by HTTP referrer in the Google Cloud console.
VITE_MAPS_BROWSER_KEY=

# Point the app at local emulators during development ("true" | "false")
VITE_USE_EMULATORS=false

# App Check debug token for local development (optional)
VITE_APPCHECK_DEBUG_TOKEN=
