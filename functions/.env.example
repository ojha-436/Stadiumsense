# Cloud Functions runtime configuration.
# In production these are set as function env vars / secrets, NOT committed.

# Vertex AI Express Mode location/model ids. Auth is via an API key (bound
# from Secret Manager as GEMINI_API_KEY — see the `secrets` global option in
# src/index.ts), NOT via a plaintext env var here.
GCLOUD_LOCATION=us-central1
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-flash

# Google Maps server key (Routes + Places). Stored in Secret Manager and bound
# to the functions that need it; never shipped to the browser.
MAPS_SERVER_KEY=

# Set AI_BACKEND=fake to use the deterministic offline gateway (tests / demo
# fallback with no billing). Any other value uses the real Gemini backend.
AI_BACKEND=gemini
